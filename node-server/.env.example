# Copy to .env and fill in.
PORT=8787

# Prisma / SQLite database file.
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="a-long-random-string-change-me"
# The account with this email becomes ADMIN (else the first-ever user does).
ADMIN_EMAIL="admin@example.com"

# Optional: serve the built React client from this Node server (single-origin).
# Defaults to ../client/build. Leave the client unbuilt to run API-only and use
# the Vite dev server (which proxies /api here).
# CLIENT_DIR="../client/build"

# Optional HTTPS
ENABLE_HTTPS=false
# KEY_PATH="./certs/key.pem"
# CERT_PATH="./certs/cert.pem"
