# The client is served by the same Cloudflare Worker as the API, so no API URL
# is needed in production. In dev, `vite` proxies /api → http://localhost:8787
# automatically (see vite.config.ts), so you usually don't need this either.
# Set it only to point the dev server at a DIFFERENT worker origin:
# VITE_API_URL=https://1k-words.your-subdomain.workers.dev
