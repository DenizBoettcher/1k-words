{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "1k-words",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-17",
  "compatibility_flags": ["nodejs_compat"],

  // Serve the built React client (client/ -> npm run build) from the same Worker.
  "assets": {
    "binding": "ASSETS",
    "directory": "../client/build"
  },

  "observability": { "enabled": true },

  // Large vendor files (piper-tts-web is a 43 MiB single JS file — over the
  // 25 MiB static-asset limit) are served from R2 instead. One-time setup:
  //   npx wrangler r2 bucket create 1k-words-vendor
  //   npx wrangler r2 object put 1k-words-vendor/piper-tts-web-1.1.2.js \
  //     --file ../client/node_modules/piper-tts-web/dist/piper-tts-web.js --remote
  "r2_buckets": [
    {
      "binding": "VENDOR",
      "bucket_name": "1k-words-vendor"
    }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      // Keep this as "1k-words" so it matches the db:migrate scripts.
      "database_name": "1k-words",
      // Local dev ignores this id. For remote/deploy run:
      //   npx wrangler d1 create 1k-words
      // and paste the returned database_id here.
      "database_id": "local-placeholder"
    }
  ]
}
