{
	"name": "cloudflare-server",
	"scripts": {
		"start": "wrangler dev",
		"deploy": "prisma generate && npm run build:client && wrangler deploy --minify",
		"build:client": "cd ../client && npm install && npm run build",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"db:migrate:local": "wrangler d1 migrations apply 1k-words --local",
		"db:migrate:remote": "wrangler d1 migrations apply 1k-words --remote",
		"prisma:generate": "prisma generate",
		"prestart": "prisma generate"
	},
	"dependencies": {
		"@prisma/adapter-d1": "^6.10.1",
		"@prisma/client": "^6.10.1",
		"bcryptjs": "^3.0.2",
		"hono": "^4.8.2",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@types/node": "^24.0.3",
		"prisma": "^6.10.1",
		"wrangler": "^4.20.5"
	}
}
